        <property name="styleSheet">
            <string notr="true">
                QMainWindow {
                background-color: #eef2f7;
                }

                QWidget#centralwidget {
                background-color: #eef2f7;
                }

                QLabel {
                color: #1f2937;
                font-family: "Segoe UI";
                font-size: 14px;
                }

                QLabel#labelTitle {
                color: #ffffff;
                font-size: 24px;
                font-weight: 700;
                }

                QLabel#labelSubtitle {
                color: #cbd5e1;
                font-size: 13px;
                }

