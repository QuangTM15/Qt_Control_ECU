                font-weight: 700;
                }

                QFrame#headerFrame {
                background-color: #0f172a;
                border-radius: 14px;
                }

                QFrame#connectionCard,
                QFrame#controlCard,
                QFrame#logCard {
                background-color: #ffffff;
                border: 1px solid #dbe3ee;
                border-radius: 14px;
                }

                QComboBox {
                min-height: 42px;
                padding-left: 14px;
                padding-right: 12px;
                color: #111827;
                background-color: #f8fafc;
                border: 1px solid #cbd5e1;
                border-radius: 8px;
                font-size: 14px;
                }

                QComboBox:hover {
                border: 1px solid #60a5fa;
                }

                QComboBox:focus {
                border: 2px solid #3b82f6;
                }

                QComboBox::drop-down {
                border: none;
                width: 32px;
                }

                QPushButton {
                min-height: 42px;
                padding: 0 20px;
                border-radius: 8px;
                font-family: "Segoe UI";
                font-size: 14px;
                font-weight: 600;
                }

                QPushButton#buttonRefresh {
                color: #334155;
                background-color: #e2e8f0;
                border: 1px solid #cbd5e1;
                }

                QPushButton#buttonRefresh:hover {
                background-color: #cbd5e1;
                }

                QPushButton#buttonConnect {
                color: #ffffff;
                background-color: #2563eb;
                border: 1px solid #2563eb;
                }

                QPushButton#buttonConnect:hover {
                background-color: #1d4ed8;
                }

                QPushButton#buttonConnect:pressed {
                background-color: #1e40af;
                }

                QPushButton#buttonOn {
                min-height: 64px;
                color: #ffffff;
                background-color: #16a34a;
                border: 1px solid #16a34a;
                font-size: 17px;
                }

                QPushButton#buttonOn:hover {
                background-color: #15803d;
                }

                QPushButton#buttonOn:pressed {
                background-color: #166534;
                }

                QPushButton#buttonOff {
                min-height: 64px;
                color: #ffffff;
                background-color: #dc2626;
                border: 1px solid #dc2626;
                font-size: 17px;
                }

                QPushButton#buttonOff:hover {
                background-color: #b91c1c;
                }

                QPushButton#buttonOff:pressed {
                background-color: #991b1b;
                }

                QPushButton:disabled {
                color: #94a3b8;
                background-color: #e2e8f0;
                border: 1px solid #cbd5e1;
                }

                QSlider::groove:horizontal {
                height: 8px;
                background-color: #dbe3ee;
                border-radius: 4px;
                }

                QSlider::sub-page:horizontal {
                background-color: #3b82f6;
                border-radius: 4px;
                }

                QSlider::add-page:horizontal {
                background-color: #dbe3ee;
                border-radius: 4px;
                }

                QSlider::handle:horizontal {
                width: 22px;
                height: 22px;
                margin: -7px 0;
                background-color: #ffffff;
                border: 3px solid #2563eb;
                border-radius: 11px;
                }

                QSlider::handle:horizontal:hover {
                border: 3px solid #1d4ed8;
                }

                QPlainTextEdit {
                color: #d1fae5;
                background-color: #111827;
                border: 1px solid #1f2937;
                border-radius: 10px;
                padding: 12px;
                font-family: "Consolas";
                font-size: 13px;
                selection-background-color: #2563eb;
                }

                QStatusBar {
                color: #475569;
                background-color: #eef2f7;
                }
            </string>
